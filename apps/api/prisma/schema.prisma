// =============================================================================
// SSC Prep Platform — Prisma schema
// Source of truth: docs/prd/14-database-architecture.md
//
// This file defines the IDENTITY & ACCESS bounded context (users, roles,
// credentials, preferences) and the AUTH SESSION context (sessions, devices).
// One-time passwords (OTP) are stored ephemerally in Redis, not here.
// Subsequent feature steps extend this schema additively (content/assessment;
// analytics; etc.) via new Prisma migrations — never by rewriting existing
// models.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  // `native` for local dev; the musl target matches the Alpine-based runtime image.
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // Extensions relied upon by the platform (doc 12 / doc 14).
  extensions = [vector, pg_trgm, pgcrypto, uuidOssp(map: "uuid-ossp")]
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserStatus {
  PENDING // account created, not yet verified
  ACTIVE
  SUSPENDED
  DEACTIVATED

  @@map("user_status")
}

enum AuthProvider {
  PASSWORD
  EMAIL_OTP
  GOOGLE

  @@map("auth_provider")
}

enum Theme {
  SYSTEM
  LIGHT
  DARK
  HIGH_CONTRAST

  @@map("theme")
}

/// Why a refresh-token session was terminated. Used for audit + reuse detection.
enum SessionRevokeReason {
  LOGOUT
  ROTATED // superseded by a newer token in the same family (normal rotation)
  REUSE_DETECTED // an already-rotated token was replayed => whole family killed
  ADMIN_REVOKED
  PASSWORD_CHANGED
  EXPIRED

  @@map("session_revoke_reason")
}

// -----------------------------------------------------------------------------
// Identity & Access
// -----------------------------------------------------------------------------

/// A platform user (aspirant, admin, etc.). Roles are assigned via UserRole.
model User {
  id        String     @id @default(uuid()) @db.Uuid
  /// E.164 phone number; primary identifier for the Indian audience (doc 15).
  phone     String?    @unique
  email     String?    @unique
  name      String?
  /// Public, unique handle used for profiles/leaderboards (doc 09).
  handle    String?    @unique
  /// BCP-47 locale, e.g. "en", "hi". Drives i18n (doc 10).
  locale    String     @default("en")
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  credentials AuthCredential[]
  roles       UserRole[]
  preferences UserPreference?
  sessions    Session[]
  devices     Device[]

  @@index([status])
  @@map("users")
}

/// A single authentication method for a user (password, email-OTP, Google, ...).
/// A user may have multiple credentials (e.g. Google + phone-OTP).
model AuthCredential {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  provider     AuthProvider
  /// Provider-specific subject id (e.g. Google `sub`). Null for password.
  providerUid  String?      @map("provider_uid")
  /// Argon2id/bcrypt hash for the PASSWORD provider only; never the raw secret.
  passwordHash String?      @map("password_hash")
  mfaEnabled   Boolean      @default(false) @map("mfa_enabled")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user has at most one credential per provider; provider uids are unique per provider.
  @@unique([userId, provider])
  @@unique([provider, providerUid])
  @@index([userId])
  @@map("auth_credentials")
}

/// System role (RBAC). Seeded with a fixed set (learner, admin, ...) in a later step.
model Role {
  id          String     @id @default(uuid()) @db.Uuid
  /// Stable, machine-readable role key, e.g. "learner", "admin".
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")

  users UserRole[]

  @@map("roles")
}

/// Join table assigning roles to users (many-to-many).
model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

/// Per-user preferences (theme, language, notifications, data saver) — doc 10 / doc 11.
model UserPreference {
  userId            String  @id @map("user_id") @db.Uuid
  theme             Theme   @default(SYSTEM)
  /// UI language (BCP-47); may differ from account `locale`.
  language          String  @default("en")
  /// Granular per-type/channel notification settings (doc 11).
  notificationPrefs Json    @default("{}") @map("notification_prefs")
  /// Local time window during which non-critical notifications are muted, e.g. "22:00-07:00".
  quietHours        String? @map("quiet_hours")
  /// Low-bandwidth data-saver mode (doc 10 — accessibility).
  dataSaver         Boolean @default(false) @map("data_saver")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}


// -----------------------------------------------------------------------------
// Auth sessions & devices (doc 15 — session & device management)
// -----------------------------------------------------------------------------

/// A client device a user signs in from. Enables "manage your devices" and
/// per-device session revocation. Identified by a stable client fingerprint.
model Device {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  /// Stable, client-generated identifier (sent via the `x-device-id` header).
  fingerprint String  @map("fingerprint")
  /// Human-friendly label, e.g. "Ravi's Android".
  name       String?
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([userId, fingerprint])
  @@index([userId])
  @@map("devices")
}

/// A refresh-token session. Each successful authentication opens a session; a
/// refresh rotates it (old row revoked as ROTATED, new row created in the same
/// `familyId`). Replaying a rotated token trips reuse detection and the whole
/// family is revoked. Only the SHA-256 hash of the refresh token is stored.
model Session {
  id               String               @id @default(uuid()) @db.Uuid
  userId           String               @map("user_id") @db.Uuid
  /// Rotation lineage: all rotations of one login share a family id.
  familyId         String               @map("family_id") @db.Uuid
  /// SHA-256 hex digest of the issued refresh token (never the raw token).
  refreshTokenHash String               @unique @map("refresh_token_hash")
  deviceId         String?              @map("device_id") @db.Uuid
  userAgent        String?              @map("user_agent")
  ipAddress        String?              @map("ip_address")
  expiresAt        DateTime             @map("expires_at")
  revokedAt        DateTime?            @map("revoked_at")
  revokedReason    SessionRevokeReason? @map("revoked_reason")
  createdAt        DateTime             @default(now()) @map("created_at")
  lastUsedAt       DateTime             @default(now()) @map("last_used_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("sessions")
}
