# =============================================================================
# SSC Prep Platform — Environment Variables (example)
# Copy to `.env` for local development: `cp .env.example .env`
# NEVER commit a real `.env`. Production values come from a secrets manager.
# The API validates these at boot via a Zod schema (apps/api/src/config).
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
# Port the NestJS API listens on.
API_PORT=4000
# Public base URL of the API (used in Swagger + links).
API_BASE_URL=http://localhost:4000
# Comma-separated list of allowed CORS origins (the Next.js web app in dev).
CORS_ORIGINS=http://localhost:3000
# Global API route prefix.
API_GLOBAL_PREFIX=api
# API version segment used in routes (e.g. /api/v1).
API_VERSION=v1

# --- Logging & Observability -------------------------------------------------
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
# Pretty-print logs in dev; set false (JSON) in production.
LOG_PRETTY=true
# Enable OpenTelemetry tracing export.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ssc-api
# OTLP/HTTP collector endpoint (e.g. http://localhost:4318).
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- PostgreSQL (OLTP + pgvector) --------------------------------------------
POSTGRES_USER=ssc
POSTGRES_PASSWORD=ssc_local_password
POSTGRES_DB=ssc_prep
POSTGRES_PORT=5432
# Prisma connection string (assembled from the values above for local dev).
DATABASE_URL=postgresql://ssc:ssc_local_password@localhost:5432/ssc_prep?schema=public

# --- Redis (cache / queues / realtime) ---------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- OpenSearch (search) -----------------------------------------------------
OPENSEARCH_PORT=9200
OPENSEARCH_NODE=http://localhost:9200

# --- ClickHouse (analytics / OLAP) -------------------------------------------
CLICKHOUSE_USER=ssc
CLICKHOUSE_PASSWORD=ssc_local_password
CLICKHOUSE_DB=ssc_analytics
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_URL=http://localhost:8123

# --- Object storage (S3-compatible / MinIO in dev) ---------------------------
MINIO_ROOT_USER=ssc
MINIO_ROOT_PASSWORD=ssc_local_password
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=ssc
S3_SECRET_ACCESS_KEY=ssc_local_password
S3_BUCKET=ssc-media
S3_FORCE_PATH_STYLE=true

# --- Auth / Security: JWT ----------------------------------------------------
# 32+ char secrets. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_dev_access_secret_change_me_please_32
JWT_REFRESH_SECRET=change_me_dev_refresh_secret_change_me_please_32
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
JWT_ISSUER=ssc-prep
JWT_AUDIENCE=ssc-prep-clients

# --- Auth / Security: One-Time Passwords (email OTP) -------------------------
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5

# --- Auth / Security: brute-force protection (password login) ----------------
LOGIN_MAX_ATTEMPTS=10
LOGIN_LOCKOUT_SECONDS=900

# --- Auth / Security: Google Sign-In -----------------------------------------
# OAuth client id used to verify Google ID tokens. Leave empty to disable Google login.
GOOGLE_CLIENT_ID=

# --- Mail (transactional email: OTP codes, etc.) -----------------------------
# `console` prints emails to the API logs (dev). Use `smtp` + SMTP_URL in production.
MAIL_TRANSPORT=console
MAIL_FROM=SSC Prep <no-reply@sscprep.local>
SMTP_URL=
